@model IEnumerable<WebBanHang_NGUYEN_VAN_THANH_2380602048.Models.Category>

@{
    ViewData["Title"] = "Category List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">Category List</h1>

<p>
    <a asp-action="Add" class="btn btn-primary">+ Add Category</a>
</p>

<table class="table table-custom">
    <thead>
        <tr>
            <th>Category Name</th>
            <th style="width:200px;">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>

                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-info btn-sm">View</a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>

</table>

        <style>
    /* PAGE TITLE */
    .page-title {
        font-weight: 600;
        margin-bottom: 20px;
    }

    /* TABLE STYLE */
    .table-custom {
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .table-custom thead {
            background: #343a40;
            color: white;
        }

        .table-custom tbody tr:hover {
            background: #f5f5f5;
        }

    /* BUTTON */
    .btn {
        border-radius: 6px;
    }
        </style>