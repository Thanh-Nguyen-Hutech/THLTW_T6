<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebBanHang</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<body>

    <!-- HEADER -->
    <header class="shop-header">

        <div class="container header-container">

            <a class="logo" asp-controller="Home" asp-action="Index">
                🛒 WebBanHang
            </a>

            <form class="search-box">
                <input type="text" placeholder="Search products..." />
            </form>

            <div class="menu-links">

                <a asp-controller="Home" asp-action="Index">Home</a>

                <a asp-controller="Product" asp-action="Index">Products</a>

                <a asp-controller="Categories" asp-action="Index">Categories</a>

            </div>

        </div>

    </header>


    <!-- MAIN CONTENT -->
    <div class="container main-content">

        <main role="main">
            @RenderBody()
        </main>

    </div>


    <!-- FOOTER -->
    <footer class="footer">

        <div class="container text-center">

            © 2026 WebBanHang
            <br />
            Simple E-Commerce Demo

        </div>

    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

            <style>
    body {
        background: #f5f5f5;
        font-family: Segoe UI, Arial;
    }

    /* HEADER */

    .shop-header {
        background: #ff5722;
        padding: 15px 0;
        margin-bottom: 30px;
    }

    .header-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .logo {
        color: white;
        font-size: 22px;
        font-weight: bold;
        text-decoration: none;
    }

    /* SEARCH */

    .search-box input {
        width: 300px;
        padding: 6px 10px;
        border: none;
        border-radius: 5px;
    }

    /* MENU */

    .menu-links a {
        color: white;
        margin-left: 20px;
        text-decoration: none;
        font-weight: 500;
    }

        .menu-links a:hover {
            text-decoration: underline;
        }

    /* MAIN */

    .main-content {
        min-height: 600px;
    }

    /* FOOTER */

    .footer {
        margin-top: 50px;
        padding: 20px;
        background: #eee;
    }
            </style>