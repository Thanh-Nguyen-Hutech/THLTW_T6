@model IEnumerable<WebBanHang_NGUYEN_VAN_THANH_2380602048.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2 class="page-title">Products</h2>

<div class="top-bar">
    <a asp-action="Add" class="btn-add">+ Add Product</a>
</div>

<div class="product-grid">

    @foreach (var item in Model)
    {
        <div class="product-card">

            <div class="product-img">
                <img src="@item.ImageUrl" alt="@item.Name">
            </div>

            <div class="product-info">

                <h4 class="product-name">
                    @item.Name
                </h4>

                <div class="product-category">
                    @item.Category?.Name
                </div>

                <div class="product-price">
                    @item.Price.ToString("N0") VND
                </div>

                <div class="product-actions">
                    <a asp-action="Display" asp-route-id="@item.Id" class="btn-view">View</a>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn-edit">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete">Delete</a>
                </div>

            </div>

        </div>
    }
</div>
    <style>
        .page-title {
            margin-bottom: 20px;
        }

        .top-bar {
            margin-bottom: 20px;
        }

        .btn-add {
            background: #ff5722;
            color: white;
            padding: 10px 15px;
            border-radius: 5px;
            text-decoration: none;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
            gap: 20px;
        }

        .product-card {
            border: 1px solid #eee;
            border-radius: 8px;
            background: white;
            overflow: hidden;
            transition: 0.3s;
        }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .product-img {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafafa;
        }

            .product-img img {
                max-width: 100%;
                max-height: 100%;
            }

        .product-info {
            padding: 15px;
        }

        .product-name {
            font-size: 16px;
            height: 40px;
            overflow: hidden;
        }

        .product-category {
            color: #888;
            font-size: 13px;
            margin-bottom: 5px;
        }

        .product-price {
            color: #e53935;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .product-actions a {
            text-decoration: none;
            font-size: 13px;
            margin-right: 8px;
        }

        .btn-view {
            color: #2196f3;
        }

        .btn-edit {
            color: #ff9800;
        }

        .btn-delete {
            color: #f44336;
        }
    </style>



