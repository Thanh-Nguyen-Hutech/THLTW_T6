@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="register-container">

    ```
    <div class="register-card">

        <h2 class="text-center mb-4">🛒 Create Account</h2>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label>Full Name</label>
                <input asp-for="Input.FullName" class="form-control custom-input" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Input.Email" class="form-control custom-input" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Input.Password" type="password" class="form-control custom-input" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control custom-input" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Role</label>
                <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-control custom-input">
                    <option disabled selected value="">Select Role</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <button type="submit" class="btn register-btn w-100 mt-3">
                Register
            </button>

        </form>

        <div class="text-center mt-3">
            <a asp-page="/Account/Login">Already have account? Login</a>
        </div>

    </div>
    ```

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .register-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff5722, #ff9800);
    }

    .register-card {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        width: 400px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .custom-input {
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 10px;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: #ff5722;
            box-shadow: 0 0 5px rgba(255,87,34,0.5);
        }

    .register-btn {
        background: linear-gradient(135deg, #ff5722, #ff9800);
        border: none;
        color: white;
        font-weight: bold;
        padding: 10px;
        border-radius: 8px;
        transition: 0.3s;
    }

        .register-btn:hover {
            opacity: 0.9;
        }
</style>

