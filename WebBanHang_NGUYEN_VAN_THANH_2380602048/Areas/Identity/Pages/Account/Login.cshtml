@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-container">

    ```
    <div class="login-card">

        <h2 class="text-center mb-4">🔐 Login</h2>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Input.Email" class="form-control custom-input" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Input.Password" type="password" class="form-control custom-input" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label">Remember me</label>
            </div>

            <button type="submit" class="btn login-btn w-100">
                Login
            </button>

            <div class="text-center mt-3">
                <a asp-page="./ForgotPassword">Forgot password?</a>
            </div>

            <div class="text-center mt-2">
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                    Don't have account? Register
                </a>
            </div>

        </form>

    </div>
    ```

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .login-container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #ff5722, #ff9800);
    }

    .login-card {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        width: 400px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .custom-input {
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 10px;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: #ff5722;
            box-shadow: 0 0 5px rgba(255,87,34,0.5);
        }

    .login-btn {
        background: linear-gradient(135deg, #ff5722, #ff9800);
        border: none;
        color: white;
        font-weight: bold;
        padding: 10px;
        border-radius: 8px;
        transition: 0.3s;
    }

        .login-btn:hover {
            opacity: 0.9;
        }
</style>

